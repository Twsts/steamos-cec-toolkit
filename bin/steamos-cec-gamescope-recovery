#!/usr/bin/env python3
"""Restart Gamescope after HDMI-CEC source activation when the display is stuck."""

from __future__ import annotations

import argparse
import asyncio
import logging
import os
import time
from pathlib import Path

from dbus_next import BusType
from dbus_next.aio import MessageBus


BUS_NAME = "com.steampowered.CecDaemon1"
DEVICE_PATH = "/com/steampowered/CecDaemon1/Devices/Cec0"
DEVICE_INTERFACE = "com.steampowered.CecDaemon1.CecDevice1"
PROPERTIES_INTERFACE = "org.freedesktop.DBus.Properties"
LOGIN1_BUS_NAME = "org.freedesktop.login1"
LOGIN1_PATH = "/org/freedesktop/login1"
LOGIN1_INTERFACE = "org.freedesktop.login1.Manager"
DEFAULT_CONFIG = "/etc/steamos-cec-toolkit.conf"
RECOVERY_DELAY_SECONDS = 3
RESUME_RECOVERY_DELAY_SECONDS = 3
RECOVERY_COOLDOWN_SECONDS = 30
CONNECTOR_POLL_SECONDS = 1.0
TV_POWER_POLL_SECONDS = 3.0
TV_POWER_TIMEOUT_SECONDS = 2.0
RUNTIME_DIR = Path(os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}"))
COOLDOWN_FILE = RUNTIME_DIR / "steamos-cec-gamescope-recovery.last"
CEC_ACTIVATION_MARKER = RUNTIME_DIR / "steamos-cec-activation-requested"

logging.basicConfig(level=logging.INFO, format="%(asctime)s %(levelname)s %(message)s")
LOG = logging.getLogger("steamos-cec-gamescope-recovery")


def read_config(path: str = DEFAULT_CONFIG) -> dict[str, str]:
    config: dict[str, str] = {}
    try:
        with open(path, encoding="utf-8") as file:
            for raw_line in file:
                line = raw_line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, value = line.split("=", 1)
                config[key.strip()] = value.strip().strip('"').strip("'")
    except FileNotFoundError:
        pass
    return config


CONFIG = read_config(os.environ.get("STEAMOS_CEC_CONFIG", DEFAULT_CONFIG))
CONNECTOR_STATUS = Path(
    CONFIG.get("GAMESCOPE_CONNECTOR_STATUS", "/sys/class/drm/card0-DP-1/status")
)
RECOVER_AFTER_RESUME = CONFIG.get("GAMESCOPE_RECOVER_AFTER_RESUME", "1") not in {
    "0",
    "false",
    "False",
    "no",
}
RECOVERY_DELAY_SECONDS = float(CONFIG.get("GAMESCOPE_RECOVERY_DELAY_SECONDS", str(RECOVERY_DELAY_SECONDS)))
RESUME_RECOVERY_DELAY_SECONDS = float(
    CONFIG.get("GAMESCOPE_RESUME_RECOVERY_DELAY_SECONDS", str(RESUME_RECOVERY_DELAY_SECONDS))
)
RECOVERY_COOLDOWN_SECONDS = float(
    CONFIG.get("GAMESCOPE_RECOVERY_COOLDOWN_SECONDS", str(RECOVERY_COOLDOWN_SECONDS))
)
CONNECTOR_POLL_SECONDS = float(
    CONFIG.get("GAMESCOPE_CONNECTOR_POLL_SECONDS", str(CONNECTOR_POLL_SECONDS))
)
CEC_DEVICE = CONFIG.get("CEC_DEVICE", "/dev/cec0")
TV_LOGICAL_ADDRESS = CONFIG.get("TV_LOGICAL_ADDRESS", "0")
RECOVER_ON_TV_POWER_ON = CONFIG.get("GAMESCOPE_RECOVER_ON_TV_POWER_ON", "1") not in {
    "0",
    "false",
    "False",
    "no",
}
RECOVER_ON_CEC_ACTIVATION = CONFIG.get("GAMESCOPE_RECOVER_ON_CEC_ACTIVATION", "1") not in {
    "0",
    "false",
    "False",
    "no",
}
TV_POWER_POLL_SECONDS = float(
    CONFIG.get("GAMESCOPE_TV_POWER_POLL_SECONDS", str(TV_POWER_POLL_SECONDS))
)
TV_POWER_TIMEOUT_SECONDS = float(
    CONFIG.get("GAMESCOPE_TV_POWER_TIMEOUT_SECONDS", str(TV_POWER_TIMEOUT_SECONDS))
)


def cooldown_remaining() -> float:
    try:
        last_recovery = float(COOLDOWN_FILE.read_text().strip())
    except (OSError, ValueError):
        return 0.0
    remaining = RECOVERY_COOLDOWN_SECONDS - (time.monotonic() - last_recovery)
    return max(0.0, remaining)


def mark_recovery_requested() -> None:
    try:
        COOLDOWN_FILE.write_text(f"{time.monotonic()}\n")
    except OSError as error:
        LOG.warning("Cannot write recovery cooldown state: %s", error)


async def command(*args: str) -> tuple[int, str]:
    process = await asyncio.create_subprocess_exec(
        *args,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.STDOUT,
    )
    stdout, _ = await process.communicate()
    return process.returncode, stdout.decode(errors="replace").strip()


async def command_with_timeout(timeout: float, *args: str) -> tuple[int, str]:
    try:
        return await asyncio.wait_for(command(*args), timeout=timeout)
    except asyncio.TimeoutError:
        return 124, "timeout"


async def recover_gamescope(reason: str, delay: float) -> None:
    await asyncio.sleep(delay)

    if CONNECTOR_STATUS.exists() and CONNECTOR_STATUS.read_text().strip() != "connected":
        LOG.warning("%s is not connected; skipping Gamescope recovery", CONNECTOR_STATUS)
        return

    returncode, _ = await command(
        "systemctl", "--user", "is-active", "--quiet", "gamescope-session.service"
    )
    if returncode != 0:
        LOG.info("Gaming Mode is not active; skipping Gamescope recovery")
        return

    LOG.info("Restarting Gamescope session target (%s)", reason)
    returncode, output = await command(
        "systemctl", "--user", "restart", "gamescope-session.target"
    )
    if returncode != 0:
        LOG.error("Gamescope recovery failed: %s", output or returncode)
        return

    LOG.info("Gamescope recovery completed")


def schedule_recovery(state: dict[str, object], reason: str) -> None:
    now = time.monotonic()
    last_recovery = float(state.get("last_recovery", 0.0))
    remaining = cooldown_remaining()
    if remaining > 0 or now - last_recovery < RECOVERY_COOLDOWN_SECONDS:
        LOG.info("Recovery suppressed by cooldown (%s)", reason)
        return

    task = state.get("task")
    if task is not None and not task.done():
        LOG.info("Recovery already pending (%s)", reason)
        return

    LOG.info("Scheduling Gamescope recovery (%s)", reason)
    state["last_recovery"] = now
    mark_recovery_requested()
    delay = RESUME_RECOVERY_DELAY_SECONDS if reason == "system resumed" else RECOVERY_DELAY_SECONDS
    state["task"] = asyncio.create_task(recover_gamescope(reason, delay))


def connector_status() -> str:
    try:
        return CONNECTOR_STATUS.read_text().strip()
    except OSError:
        return "unknown"


def parse_power_status(output: str) -> str:
    for line in output.splitlines():
        if "pwr-state:" not in line:
            continue
        return line.split("pwr-state:", 1)[1].split("(", 1)[0].strip().lower()
    return "unknown"


async def tv_power_status() -> str:
    if not Path(CEC_DEVICE).exists():
        return "missing-cec-device"
    returncode, output = await command_with_timeout(
        TV_POWER_TIMEOUT_SECONDS,
        "cec-ctl",
        "-d",
        CEC_DEVICE,
        "-s",
        "--to",
        TV_LOGICAL_ADDRESS,
        "--give-device-power-status",
    )
    if returncode != 0:
        return "unknown"
    return parse_power_status(output)


async def monitor_cec(state: dict[str, object]) -> None:
    bus = await MessageBus().connect()
    introspection = await bus.introspect(BUS_NAME, DEVICE_PATH)
    proxy = bus.get_proxy_object(BUS_NAME, DEVICE_PATH, introspection)
    properties = proxy.get_interface(PROPERTIES_INTERFACE)

    active_variant = await properties.call_get(DEVICE_INTERFACE, "Active")
    state["active"] = bool(active_variant.value)
    LOG.info("Monitoring CEC Active state; initial state=%s", state["active"])

    def properties_changed(interface_name, changed, _invalidated):
        if interface_name != DEVICE_INTERFACE or "Active" not in changed:
            return

        active = bool(changed["Active"].value)
        previous = state["active"]
        state["active"] = active
        LOG.info("CEC Active changed: %s -> %s", previous, active)

        if not active or previous:
            return

        schedule_recovery(state, "CEC source became active")

    properties.on_properties_changed(properties_changed)
    await asyncio.get_running_loop().create_future()


async def monitor_connector(state: dict[str, object]) -> None:
    previous = connector_status()
    state["connector_status"] = previous
    LOG.info("Monitoring DRM connector %s; initial state=%s", CONNECTOR_STATUS, previous)

    while True:
        await asyncio.sleep(CONNECTOR_POLL_SECONDS)
        current = connector_status()
        if current == previous:
            continue

        LOG.info("DRM connector changed: %s -> %s", previous, current)
        state["connector_status"] = current

        if previous != "connected" and current == "connected" and state.get("active"):
            schedule_recovery(state, "display reconnected while CEC source active")

        previous = current


async def monitor_tv_power(state: dict[str, object]) -> None:
    if not RECOVER_ON_TV_POWER_ON:
        LOG.info("TV power recovery disabled by config")
        await asyncio.get_running_loop().create_future()

    previous = await tv_power_status()
    state["tv_power_status"] = previous
    LOG.info("Monitoring TV CEC power status; initial state=%s", previous)

    while True:
        await asyncio.sleep(TV_POWER_POLL_SECONDS)
        current = await tv_power_status()
        if current == previous:
            continue

        LOG.info("TV CEC power changed: %s -> %s", previous, current)
        state["tv_power_status"] = current

        if previous != "on" and current == "on" and state.get("active"):
            schedule_recovery(state, "TV powered on while CEC source active")

        previous = current


async def monitor_cec_activation_marker(state: dict[str, object]) -> None:
    if not RECOVER_ON_CEC_ACTIVATION:
        LOG.info("CEC activation recovery disabled by config")
        await asyncio.get_running_loop().create_future()

    try:
        previous_mtime = CEC_ACTIVATION_MARKER.stat().st_mtime
    except OSError:
        previous_mtime = 0.0

    LOG.info("Monitoring CEC activation requests for Gamescope recovery")

    while True:
        await asyncio.sleep(CONNECTOR_POLL_SECONDS)
        try:
            current_mtime = CEC_ACTIVATION_MARKER.stat().st_mtime
        except OSError:
            current_mtime = 0.0

        if current_mtime <= previous_mtime:
            continue

        previous_mtime = current_mtime
        if not state.get("active"):
            LOG.info("CEC activation requested while source is not active yet; waiting for active state")
            continue

        schedule_recovery(state, "CEC activation requested")


async def monitor_sleep(state: dict[str, object]) -> None:
    if not RECOVER_AFTER_RESUME:
        LOG.info("Resume recovery disabled by config")
        await asyncio.get_running_loop().create_future()

    try:
        bus = await MessageBus(bus_type=BusType.SYSTEM).connect()
        introspection = await bus.introspect(LOGIN1_BUS_NAME, LOGIN1_PATH)
        proxy = bus.get_proxy_object(LOGIN1_BUS_NAME, LOGIN1_PATH, introspection)
        manager = proxy.get_interface(LOGIN1_INTERFACE)
    except Exception as error:
        LOG.warning("Cannot monitor system resume: %s", error)
        await asyncio.get_running_loop().create_future()

    def prepare_for_sleep(sleeping):
        LOG.info("PrepareForSleep sleeping=%s", sleeping)
        if sleeping:
            return
        schedule_recovery(state, "system resumed")

    manager.on_prepare_for_sleep(prepare_for_sleep)
    LOG.info("Monitoring system resume for Gamescope recovery")
    await asyncio.get_running_loop().create_future()


async def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--recover-now", action="store_true")
    args = parser.parse_args()

    if args.recover_now:
        await recover_gamescope("manual", 0)
    else:
        state: dict[str, object] = {
            "active": False,
            "last_recovery": 0.0,
            "task": None,
        }
        await asyncio.gather(
            monitor_cec(state),
            monitor_connector(state),
            monitor_tv_power(state),
            monitor_cec_activation_marker(state),
            monitor_sleep(state),
        )


if __name__ == "__main__":
    asyncio.run(main())
