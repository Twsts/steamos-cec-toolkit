#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="${STEAMOS_CEC_CONFIG:-/etc/steamos-cec-toolkit.conf}"
if [[ -r "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi

if [[ "${1:-}" == "post" ]]; then
  exit 0
fi

STEAMOS_CEC_USER="${STEAMOS_CEC_USER:-deck}"
STEAMOS_CEC_UID="$(id -u "$STEAMOS_CEC_USER")"
CEC_DEVICE="${CEC_DEVICE:-/dev/cec0}"
TV_LOGICAL_ADDRESS="${TV_LOGICAL_ADDRESS:-0}"
CEC_PLAYBACK_LOGICAL_ADDRESS="${CEC_PLAYBACK_LOGICAL_ADDRESS:-4}"
TV_STANDBY_SETTLE_SECONDS="${TV_STANDBY_SETTLE_SECONDS:-2}"
INPUT_INACTIVE_SUSPEND_MARKER="/run/user/$STEAMOS_CEC_UID/steamos-cec-input-inactive-suspend"

touch /run/steamos-cec-local-suspend

run_as_user_bus() {
  runuser -u "$STEAMOS_CEC_USER" -- env \
    XDG_RUNTIME_DIR="/run/user/$STEAMOS_CEC_UID" \
    DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$STEAMOS_CEC_UID/bus" \
    "$@"
}

current_playback_logical_address() {
  local logical
  logical="$(/usr/bin/cec-ctl -d "$CEC_DEVICE" -l 2>/dev/null | awk '/^[[:space:]]*[0-9]+[[:space:]]*$/ {print $1; exit}')"
  if [[ "$logical" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$logical"
    return
  fi

  logical="$(
    /usr/bin/cec-ctl -d "$CEC_DEVICE" -S 2>/dev/null |
      awk '/^[[:space:]]+Logical Address[[:space:]]+:/ {print $4; exit}'
  )"
  if [[ "$logical" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$logical"
  else
    printf '%s\n' "$CEC_PLAYBACK_LOGICAL_ADDRESS"
  fi
}

send_native_standby() {
  /usr/bin/cec-ctl -d "$CEC_DEVICE" -s --to "$1" --standby || true
}

send_raw_standby() {
  local source="$1"
  local target="$2"
  /usr/bin/cec-ctl -d "$CEC_DEVICE" -s --raw-msg \
    -f "$source" -t "$target" \
    --custom-command cmd=0x36 || true
}

input_inactive_suspend_in_progress() {
  [[ -e "$INPUT_INACTIVE_SUSPEND_MARKER" ]] || return 1

  local marker_mtime now age
  marker_mtime="$(stat -c %Y "$INPUT_INACTIVE_SUSPEND_MARKER" 2>/dev/null || printf 0)"
  now="$(date +%s)"
  age=$((now - marker_mtime))
  [[ "$age" -ge 0 && "$age" -lt 180 ]]
}

if input_inactive_suspend_in_progress; then
  echo "steamos-cec: input-inactive suspend detected; skipping TV/AVR standby"
  exit 0
fi

echo "steamos-cec: sending TV standby before sleep/shutdown"

if [[ -e "$CEC_DEVICE" ]]; then
  playback_logical_address="$(current_playback_logical_address)"
  echo "steamos-cec: CEC standby source logical address $playback_logical_address"

  send_native_standby "$TV_LOGICAL_ADDRESS"
  sleep 0.25
  send_raw_standby "$playback_logical_address" "$TV_LOGICAL_ADDRESS"
  sleep 0.25
  send_native_standby 15
  sleep 0.25
  send_raw_standby "$playback_logical_address" 15
fi

run_as_user_bus busctl --user call \
  com.steampowered.CecDaemon1 \
  /com/steampowered/CecDaemon1/Daemon \
  com.steampowered.CecDaemon1.Daemon1 \
  Standby b true \
  || true

run_as_user_bus busctl --user call \
  com.steampowered.CecDaemon1 \
  /com/steampowered/CecDaemon1/Devices/Cec0 \
  com.steampowered.CecDaemon1.CecDevice1 \
  Standby y "$TV_LOGICAL_ADDRESS" \
  || true

if [[ -e "$CEC_DEVICE" ]]; then
  for delay in 0.5 1.0; do
    sleep "$delay"
    send_raw_standby "$playback_logical_address" "$TV_LOGICAL_ADDRESS"
    sleep 0.25
    send_raw_standby "$playback_logical_address" 15
  done
fi

sleep "$TV_STANDBY_SETTLE_SECONDS"
